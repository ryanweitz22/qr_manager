<h2 style="margin-bottom: 20px;">Forgot your password?</h2>

<%= form_for(resource, as: resource_name, url: password_path(resource_name), html: { method: :post }) do |f| %>
  <%= render "devise/shared/error_messages", resource: resource %>

  <div style="margin-bottom: 20px;">
    <%= f.label :email, style: "display:block; font-weight:600; margin-bottom:6px;" %>
    <%= f.email_field :email, autofocus: true, autocomplete: "email", style: "width: 100%; max-width: 400px; padding: 10px; border: 1px solid #ccc; border-radius: 4px; font-size:15px;" %>
  </div>

  <div>
    <%= f.submit "Send me password reset instructions", style: "background: #1976D2; color: white; padding: 10px 24px; border: none; border-radius: 4px; cursor: pointer; font-size: 15px;" %>
  </div>
<% end %>

<div style="margin-top: 20px;">
  <%= render "devise/shared/links" %>
</div>