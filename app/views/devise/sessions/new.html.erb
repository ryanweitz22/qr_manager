<h2 style="margin-bottom: 20px;">Log in</h2>

<%= form_for(resource, as: resource_name, url: session_path(resource_name)) do |f| %>
  <div style="margin-bottom: 16px;">
    <%= f.label :email, style: "display:block; font-weight:600; margin-bottom:6px;" %>
    <%= f.email_field :email, autofocus: true, autocomplete: "email", style: "width: 100%; max-width: 400px; padding: 10px; border: 1px solid #ccc; border-radius: 4px; font-size:15px;" %>
  </div>

  <div style="margin-bottom: 16px;">
    <%= f.label :password, style: "display:block; font-weight:600; margin-bottom:6px;" %>
    <%= f.password_field :password, autocomplete: "current-password", style: "width: 100%; max-width: 400px; padding: 10px; border: 1px solid #ccc; border-radius: 4px; font-size:15px;" %>
  </div>

  <% if devise_mapping.rememberable? %>
    <div style="margin-bottom: 20px;">
      <%= f.check_box :remember_me, style: "margin-right: 6px;" %>
      <%= f.label :remember_me %>
    </div>
  <% end %>

  <div>
    <%= f.submit "Log in", style: "background: #1976D2; color: white; padding: 10px 24px; border: none; border-radius: 4px; cursor: pointer; font-size: 15px;" %>
  </div>
<% end %>

<div style="margin-top: 20px;">
  <%= render "devise/shared/links" %>
</div>