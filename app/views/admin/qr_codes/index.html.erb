<h1>QR Codes</h1>

<p class="content-actions" style="display:flex; flex-wrap:wrap; gap:10px; margin-bottom:15px;">
  <%= link_to "➕ Create New QR Code", new_admin_qr_code_path,
      style: "display:inline-block; background: #1976D2; color: white; padding: 8px 16px; border-radius: 4px; text-decoration: none;" %>
  <%= link_to "🗄 View Archived QR Codes", archived_admin_qr_codes_path,
      style: "display:inline-block; background: #666; color: white; padding: 8px 16px; border-radius: 4px; text-decoration: none;" %>
</p>

<form method="get" action="/admin/qr_codes" style="margin: 15px 0;">
  <input type="text" name="q" value="<%= params[:q] %>"
         placeholder="Search QR codes by name..."
         style="padding: 7px; width: 280px; border: 1px solid #ccc; border-radius: 4px;">
  <button type="submit" style="padding: 7px 14px; background: #555; color: white; border: none; border-radius: 4px; cursor: pointer;">
    Search
  </button>
  <% if params[:q].present? %>
    <%= link_to "✖ Clear", admin_qr_codes_path, style: "margin-left: 8px; color: red;" %>
  <% end %>
</form>

<table border="1" cellpadding="10" style="width: 100%; border-collapse: collapse; margin-top: 10px;">
  <thead>
    <tr style="background: #f0f0f0; text-align: left;">
      <th>Name</th>
      <th>Slug</th>
      <th>Destination URL</th>
      <th>Active?</th>
      <th>Total Scans</th>
      <th>Created</th>
      <th>Actions</th>
    </tr>
  </thead>
  <tbody>
    <% @qr_codes.each do |qr| %>
      <tr>
        <td><strong><%= qr.name %></strong></td>
        <td><code style="font-size: 12px;">/q/<%= qr.slug %></code></td>
        <td><%= truncate(qr.destination_url, length: 40) %></td>
        <td style="color: <%= qr.active? ? 'green' : 'red' %>; font-weight: bold;">
          <%= qr.active? ? "✅ Yes" : "❌ No" %>
        </td>
        <td style="text-align: center;"><strong><%= qr.qr_scans.count %></strong></td>
        <td><%= qr.created_at.strftime("%d %b %Y") %></td>
        <td style="white-space: nowrap;">
          <%= link_to "View", admin_qr_code_path(qr), style: "display:inline-block; padding: 4px 10px; background:#1976D2; color:white; border-radius:4px; text-decoration:none; font-size:13px; margin:2px;" %>
          <%= link_to "Edit", edit_admin_qr_code_path(qr), style: "display:inline-block; padding: 4px 10px; background:#FF8C00; color:white; border-radius:4px; text-decoration:none; font-size:13px; margin:2px;" %>
          <%= button_to "Archive", archive_admin_qr_code_path(qr), method: :patch, data: { confirm: "Archive #{qr.name}? It will be hidden from the main list." }, style: "display:inline-block; padding: 4px 10px; background:#555; color:white; border-radius:4px; border:none; font-size:13px; cursor:pointer; margin:2px;" %>
          <%= button_to "Delete", admin_qr_code_path(qr), method: :delete, data: { turbo_method: :delete, turbo_confirm: "Delete #{qr.name}? This cannot be undone." }, style: "display:inline-block; padding: 4px 10px; background:#D32F2F; color:white; border-radius:4px; border:none; font-size:13px; cursor:pointer; margin:2px;" %>
        </td>
      </tr>
    <% end %>
  </tbody>
</table>

<% if @qr_codes.empty? %>
  <p style="color: #666; margin-top: 20px; font-size: 16px;">
    No QR codes found.
    <%= link_to "Create your first one!", new_admin_qr_code_path %>
  </p>
<% end %>
