<!-- form_with creates the HTML form and submits to the correct URL automatically -->
<!-- model: [:admin, @qr_code] tells Rails this form is in the admin namespace -->
<%= form_with model: [:admin, @qr_code] do |f| %>

  <!-- Show validation errors if the form was submitted with bad data -->
  <% if @qr_code.errors.any? %>
    <div style="color: red; background: #ffebee; padding: 12px; margin-bottom: 15px; border-radius: 4px; border: 1px solid #f44336;">
      <strong>Please fix these errors before saving:</strong>
      <ul style="margin: 8px 0 0 20px;">
        <% @qr_code.errors.full_messages.each do |msg| %>
          <li><%= msg %></li>
        <% end %>
      </ul>
    </div>
  <% end %>

  <!-- Name field -->
  <div style="margin-bottom: 16px;">
    <%= f.label :name, "QR Code Name *", style: "display:block; font-weight:600; margin-bottom:6px;" %>
    <%= f.text_field :name, placeholder: "e.g. Business Card QR", style: "width: 100%; max-width: 500px; padding: 10px; border: 1px solid #ccc; border-radius: 4px; font-size:15px;" %>
  </div>

  <!-- Slug field — auto generated from name but can be overridden -->
  <div style="margin-bottom: 16px;">
    <%= f.label :slug, "Slug (URL identifier) *", style: "display:block; font-weight:600; margin-bottom:6px;" %>
    <%= f.text_field :slug, placeholder: "e.g. business-card-qr", style: "width: 100%; max-width: 500px; padding: 10px; border: 1px solid #ccc; border-radius: 4px; font-size:15px;" %>
    <small style="color: #666; display:block; margin-top:4px;">This becomes the public URL: /q/your-slug-here<br>Leave blank to auto-generate from the name above.</small>
  </div>

  <!-- Destination URL -->
  <div style="margin-bottom: 16px;">
    <%= f.label :destination_url, "Destination URL *", style: "display:block; font-weight:600; margin-bottom:6px;" %>
    <%= f.url_field :destination_url, placeholder: "https://example.com", style: "width: 100%; max-width: 500px; padding: 10px; border: 1px solid #ccc; border-radius: 4px; font-size:15px;" %>
    <small style="color: #666; display:block; margin-top:4px;">Where the QR code redirects to. You can change this at any time.</small>
  </div>

  <!-- Active toggle -->
  <div style="margin-bottom: 20px;">
    <%= f.check_box :active, style: "margin-right: 6px;" %>
    <%= f.label :active, "Active — QR code will redirect when scanned" %>
  </div>

  <!-- Submit button -->
  <div>
    <%= f.submit style: "background: #1976D2; color: white; padding: 10px 24px; border: none; border-radius: 4px; cursor: pointer; font-size: 15px;" %>
    <%= link_to "Cancel", admin_qr_codes_path, style: "display:inline-block; padding: 10px 20px; background:#eee; color:#333; border-radius:4px; text-decoration:none; font-size:15px; margin-left:8px;" %>
  </div>

<% end %>