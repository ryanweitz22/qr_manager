<h1>Archived QR Codes</h1>

<p>
  <%= link_to "← Back to Active QR Codes", admin_qr_codes_path, style: "display:inline-block; padding: 6px 14px; background:#eee; color:#333; border-radius:4px; text-decoration:none; font-size:14px;" %>
</p>

<hr>

<% if @qr_codes.empty? %>
  <p style="color: #666;">No archived QR codes.</p>
<% else %>
  <table border="1" cellpadding="8" cellspacing="0" style="width:100%; border-collapse:collapse;">
    <thead>
      <tr style="background:#f0f0f0;">
        <th>Name</th>
        <th>Slug</th>
        <th>Destination URL</th>
        <th>Total Scans</th>
        <th>Archived</th>
        <th>Actions</th>
      </tr>
    </thead>
    <tbody>
      <% @qr_codes.each do |qr| %>
        <tr>
          <td><%= qr.name %></td>
          <td><code style="font-size:12px;"><%= qr.slug %></code></td>
          <td><%= truncate(qr.destination_url, length: 40) %></td>
          <td><%= qr.qr_scans.count %></td>
          <td><%= qr.created_at.strftime("%d %b %Y") %></td>
          <td style="white-space:nowrap;">
            <%= link_to "View", admin_qr_code_path(qr), style: "display:inline-block; padding: 4px 10px; background:#1976D2; color:white; border-radius:4px; text-decoration:none; font-size:13px; margin:2px;" %>
            <%= button_to "Restore", unarchive_admin_qr_code_path(qr), method: :patch, data: { confirm: "Restore this QR code?" }, style: "display:inline-block; padding: 4px 10px; background:#388E3C; color:white; border-radius:4px; border:none; font-size:13px; cursor:pointer; margin:2px;" %>
            <%= button_to "Delete", admin_qr_code_path(qr), method: :delete, data: { confirm: "Permanently delete #{qr.name}? This cannot be undone." }, style: "display:inline-block; padding: 4px 10px; background:#D32F2F; color:white; border-radius:4px; border:none; font-size:13px; cursor:pointer; margin:2px;" %>
          </td>
        </tr>
      <% end %>
    </tbody>
  </table>
<% end %>