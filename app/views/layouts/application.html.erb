<!DOCTYPE html>
<html>
  <head>
    <title>QR Manager</title>
    <meta name="viewport" content="width=device-width,initial-scale=1">
    <%= csrf_meta_tags %>
    <%= csp_meta_tag %>
    <%= stylesheet_link_tag "application" %>
    <%= javascript_importmap_tags %>
  </head>

  <body style="font-family: Arial, sans-serif; max-width: 1100px; margin: 0 auto; padding: 20px;">

  <nav style="border-bottom: 2px solid #e0e0e0; padding: 12px 20px; margin-bottom: 24px; display: flex; justify-content: space-between; align-items: center; background: white;">
    <strong style="font-size: 20px; color: #222;">📱 QR Manager</strong>
    <% if admin_user_signed_in? %>
      <div style="display: flex; align-items: center; gap: 10px;">
        <%= link_to "QR Codes", admin_qr_codes_path, style: "display:inline-block; padding: 6px 14px; background:#1976D2; color:white; border-radius:4px; text-decoration:none; font-size:14px;" %>
        <%= link_to "Logout", destroy_admin_user_session_path, data: { turbo_method: :delete }, style: "display:inline-block; padding: 6px 14px; background:#D32F2F; color:white; border-radius:4px; text-decoration:none; font-size:14px;" %>
        <small style="color: #666; font-size:13px;">👤 <%= current_admin_user.email %></small>
      </div>
    <% end %>
  </nav>

    <!-- Flash messages — shown after actions like create, update, delete -->
    <!-- notice = green success messages -->
    <% if notice %>
      <p style="color: green; background: #e8f5e9; padding: 10px; border-radius: 4px; margin-bottom: 15px;">
        ✅ <%= notice %>
      </p>
    <% end %>

    <!-- alert = red error messages like wrong password -->
    <% if alert %>
      <p style="color: red; background: #ffebee; padding: 10px; border-radius: 4px; margin-bottom: 15px;">
        ❌ <%= alert %>
      </p>
    <% end %>

    <!-- Each page's unique content gets inserted here -->
    <%= yield %>

  </body>
</html>